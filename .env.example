# ========================================
# SENDGRID EMAIL CONFIGURATION
# ========================================
# Get your SendGrid API key from: https://app.sendgrid.com/settings/api_keys
# Follow setup guide: SENDGRID_SETUP_GUIDE.md

# Your SendGrid API Key (starts with "SG.")
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Verified sender email (must be verified in SendGrid dashboard)
SENDGRID_FROM_EMAIL=noreply@yourcompany.com

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_URL=jdbc:postgresql://localhost:5432/omoiservespare
DB_USERNAME=postgres
DB_PASSWORD=your-database-password

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_SECRET=your-jwt-secret-key-at-least-256-bits

# ========================================
# CLOUDINARY (Image Upload)
# ========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========================================
# RAZORPAY PAYMENT GATEWAY
# ========================================
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ========================================
# GOOGLE MAPS API
# ========================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ========================================
# REDIS (Optional)
# ========================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ========================================
# TWILIO (SMS - Optional)
# ========================================
TWILIO_SID=dummy_key
TWILIO_AUTH_TOKEN=dummy_key
TWILIO_PHONE_NUMBER=+10000000000

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=8080
